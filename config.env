# BirdWatch-Pi configuratie
# Pas aan voor jouw setup – daarna: docker compose restart

# Microfoon: 'default', een indexnummer (0,1,2) of naam-fragment
AUDIO_DEVICE=default

# Sample rate in Hz (48000 aanbevolen voor BirdNET)
SAMPLE_RATE=48000

# Minimale betrouwbaarheid voor waarnemingen (0.0 – 1.0)
MIN_CONFIDENCE=0.70

# GPS-locatie voor seizoensgebonden soortfiltering
LOCATION_LAT=52.30
LOCATION_LON=5.00

# Taal van soortnamen: nl, en, de, fr
LANGUAGE=nl
